# Bitget API 鍑瘉锛堝彧璇绘潈闄愬嵆鍙級
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here
BITGET_SIMULATED=1

# 閲囬泦闂撮殧锛堢锛夛紝榛樿 5 绉?POLL_INTERVAL=5

# 鏃ュ織绾у埆锛欴EBUG / INFO / WARNING
LOG_LEVEL=INFO

# Binance Futures (default for simulated page: testnet)
BINANCE_API_KEY=your_binance_key_here
BINANCE_API_SECRET=your_binance_secret_here
BINANCE_BASE_URL=https://testnet.binancefuture.com

# Binance Copy-trade (public BAPI)
BINANCE_COPYTRADE_BASE=https://www.binance.com
# Optional proxy for Binance copy-trade endpoints, e.g. http://127.0.0.1:7890
BINANCE_COPYTRADE_PROXY=
# Fallback proxy used when BINANCE_COPYTRADE_PROXY is empty
BINANCE_PROXY=
